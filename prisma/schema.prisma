generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Document {
  id        String                 @id @default(uuid())
  content   String
  metadata  Json?
  embedding Unsupported("vector")?
  createdAt DateTime               @default(now())
  updatedAt DateTime               @updatedAt
  tenantId  String
  tenant    Tenant                 @relation(fields: [tenantId], references: [id])

  @@map("documents")
}

model Tenant {
  id                      String                  @id @default(dbgenerated("gen_random_uuid()"))
  name                    String
  domain                  String                  @unique
  logo                    String?
  createdAt               DateTime                @default(now())
  updatedAt               DateTime                @updatedAt
  analyticsSnapshots      AnalyticsSnapshot[]
  distinctiveCapabilities DistinctiveCapability[]
  EmergentInsight         EmergentInsight[]
  hardChoices             HardChoice[]
  initiatives             Initiative[]
  kanbanTasks             KanbanTask[]
  keyResults              KeyResult[]
  marketValueMetrics      MarketValueMetric[]
  megas                   Mega[]
  mutationLogs            MutationLog[]
  objectives              Objective[]
  values                  OrganizationalValue[]
  purposes                Purpose[]
  rituals                 Ritual[]
  strategicAccess         StrategicAccess[]
  strategicAxes           StrategicAxis[]
  strategicConversations  StrategicConversation[]
  strategicGoals          StrategicGoal[]
  teams                   Team[]
  users                   User[]
  Document                Document[]
}

model User {
  id                   String              @id @default(uuid())
  email                String              @unique
  name                 String
  lastName             String?
  age                  Int?
  gender               String?
  jobTitle             String?
  area                 String?
  tenure               String?
  hierarchyLevel       Int?                @default(3)
  tenantId             String
  role                 UserRole            @default(COLLABORATOR)
  jobRole              JobRole?
  createdAt            DateTime            @default(now())
  updatedAt            DateTime            @updatedAt
  discProfile          DiscProfile?
  ownedInitiatives     Initiative[]
  kanbanTasks          KanbanTask[]
  ownedKeyResults      KeyResult[]
  keyResultUpdates     KeyResultUpdate[]
  ownedObjectives      Objective[]
  ownedPurposes        Purpose[]
  ritualActionLogs     RitualActionLog[]
  ritualCommitments    RitualCommitment[]
  ritualParticipations RitualParticipant[]
  strategicAccess      StrategicAccess[]
  ledTeams             Team[]              @relation("TeamLeader")
  teams                TeamMember[]
  tenant               Tenant              @relation(fields: [tenantId], references: [id])
}

model DiscProfile {
  id        String    @id @default(uuid())
  userId    String    @unique
  color     DiscColor
  scores    String
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  user      User      @relation(fields: [userId], references: [id])
}

model Team {
  id          String       @id @default(uuid())
  name        String
  tenantId    String
  aiReasoning String?
  leaderId    String?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  initiatives Initiative[]
  leader      User?        @relation("TeamLeader", fields: [leaderId], references: [id])
  tenant      Tenant       @relation(fields: [tenantId], references: [id])
  members     TeamMember[]
}

model TeamMember {
  id     String  @id @default(uuid())
  teamId String
  userId String
  role   String?
  team   Team    @relation(fields: [teamId], references: [id])
  user   User    @relation(fields: [userId], references: [id])

  @@unique([teamId, userId])
}

model Purpose {
  id              String            @id @default(uuid())
  statement       String
  type            PurposeType       @default(COMPANY)
  ownerId         String?
  tenantId        String
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  area            String?
  megas           Mega[]
  owner           User?             @relation(fields: [ownerId], references: [id])
  tenant          Tenant            @relation(fields: [tenantId], references: [id])
  strategicAccess StrategicAccess[]
}

model Mega {
  id         String      @id @default(uuid())
  statement  String
  deadline   DateTime
  purposeId  String
  tenantId   String
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt
  purpose    Purpose     @relation(fields: [purposeId], references: [id])
  tenant     Tenant      @relation(fields: [tenantId], references: [id])
  objectives Objective[]
}

model Objective {
  id                String            @id @default(uuid())
  statement         String
  description       String?
  megaId            String?
  parentObjectiveId String?
  ownerId           String?
  tenantId          String
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt
  area              String?
  weight            Float             @default(1.0)
  strategicAxisId   String?
  keyResults        KeyResult[]
  mega              Mega?             @relation(fields: [megaId], references: [id])
  owner             User?             @relation(fields: [ownerId], references: [id])
  parentObjective   Objective?        @relation("RecursiveObjectives", fields: [parentObjectiveId], references: [id])
  childObjectives   Objective[]       @relation("RecursiveObjectives")
  strategicAxis     StrategicAxis?    @relation(fields: [strategicAxisId], references: [id])
  tenant            Tenant            @relation(fields: [tenantId], references: [id])
  strategicAccess   StrategicAccess[]
}

model KeyResult {
  id                   String               @id @default(uuid())
  statement            String
  description          String?
  targetValue          Float
  currentValue         Float                @default(0)
  metricUnit           String
  objectiveId          String
  ownerId              String?
  tenantId             String
  createdAt            DateTime             @default(now())
  updatedAt            DateTime             @updatedAt
  numeratorValue       Float                @default(0)
  denominatorValue     Float                @default(1)
  numeratorLabel       String               @default("Actual")
  denominatorLabel     String               @default("Meta")
  trackingType         TrackingType         @default(PERCENTAGE)
  updatePeriodicity    UpdatePeriodicity?
  weight               Float                @default(1.0)
  startYear            Int?
  startQuarter         Int?
  endYear              Int?
  endQuarter           Int?
  measurementDirection MeasurementDirection @default(MAXIMIZE)
  initiatives          Initiative[]
  objective            Objective            @relation(fields: [objectiveId], references: [id])
  owner                User?                @relation(fields: [ownerId], references: [id])
  tenant               Tenant               @relation(fields: [tenantId], references: [id])
  updates              KeyResultUpdate[]
}

model KeyResultUpdate {
  id          String    @id @default(uuid())
  keyResultId String
  oldValue    Float
  newValue    Float
  userId      String?
  createdAt   DateTime  @default(now())
  comment     String?
  obstacles   String?
  keyResult   KeyResult @relation(fields: [keyResultId], references: [id], onDelete: Cascade)
  user        User?     @relation(fields: [userId], references: [id])
}

model Initiative {
  id              String            @id @default(uuid())
  title           String
  description     String?
  horizon         Horizon
  status          KanbanStatus      @default(TODO)
  progress        Float             @default(0)
  keyResultId     String
  ownerId         String?
  teamId          String?
  aiExplanation   String?
  tenantId        String
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  keyResult       KeyResult         @relation(fields: [keyResultId], references: [id])
  owner           User?             @relation(fields: [ownerId], references: [id])
  team            Team?             @relation(fields: [teamId], references: [id])
  tenant          Tenant            @relation(fields: [tenantId], references: [id])
  tasks           KanbanTask[]
  strategicAccess StrategicAccess[]
}

model KanbanTask {
  id           String       @id @default(uuid())
  title        String
  description  String?
  status       KanbanStatus @default(TODO)
  initiativeId String
  assigneeId   String?
  tenantId     String
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
  assignee     User?        @relation(fields: [assigneeId], references: [id])
  initiative   Initiative   @relation(fields: [initiativeId], references: [id], onDelete: Cascade)
  tenant       Tenant       @relation(fields: [tenantId], references: [id])
}

model Ritual {
  id               String              @id @default(uuid())
  name             String
  date             DateTime
  description      String?
  discussionPoints String?
  aiSuggestions    String?
  tenantId         String
  createdAt        DateTime            @default(now())
  updatedAt        DateTime            @updatedAt
  status           RitualStatus        @default(SCHEDULED)
  tenant           Tenant              @relation(fields: [tenantId], references: [id])
  actionLogs       RitualActionLog[]
  commitments      RitualCommitment[]
  participants     RitualParticipant[]
}

model RitualParticipant {
  id       String @id @default(uuid())
  ritualId String
  userId   String
  ritual   Ritual @relation(fields: [ritualId], references: [id], onDelete: Cascade)
  user     User   @relation(fields: [userId], references: [id])

  @@unique([ritualId, userId])
}

model RitualCommitment {
  id          String           @id @default(uuid())
  description String
  status      CommitmentStatus @default(PENDING)
  dueDate     DateTime?
  ritualId    String
  ownerId     String?
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  owner       User?            @relation(fields: [ownerId], references: [id])
  ritual      Ritual           @relation(fields: [ritualId], references: [id], onDelete: Cascade)
}

model RitualActionLog {
  id        String   @id @default(uuid())
  action    String
  details   String?
  createdAt DateTime @default(now())
  ritualId  String
  userId    String
  ritual    Ritual   @relation(fields: [ritualId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model HardChoice {
  id          String   @id @default(uuid())
  description String
  reasoning   String
  date        DateTime @default(now())
  tenantId    String
  tenant      Tenant   @relation(fields: [tenantId], references: [id])
}

model StrategicConversation {
  id           String   @id @default(uuid())
  topic        String
  conclusion   String?
  participants String?
  date         DateTime @default(now())
  tenantId     String
  tenant       Tenant   @relation(fields: [tenantId], references: [id])
}

model DistinctiveCapability {
  id       String  @id @default(uuid())
  name     String
  status   String
  evidence String?
  tenantId String
  tenant   Tenant  @relation(fields: [tenantId], references: [id])
}

model MarketValueMetric {
  id             String   @id @default(uuid())
  metricName     String
  value          Float
  marketFeedback String?
  date           DateTime @default(now())
  tenantId       String
  tenant         Tenant   @relation(fields: [tenantId], references: [id])
}

model MutationLog {
  id          String   @id @default(uuid())
  observation String
  type        String
  ignore      Boolean  @default(false)
  date        DateTime @default(now())
  tenantId    String
  tenant      Tenant   @relation(fields: [tenantId], references: [id])
}

model OrganizationalValue {
  id        String   @id @default(uuid())
  statement String
  tenantId  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  tenant    Tenant   @relation(fields: [tenantId], references: [id])
}

model StrategicAxis {
  id         String      @id @default(uuid())
  statement  String
  tenantId   String
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt
  objectives Objective[]
  tenant     Tenant      @relation(fields: [tenantId], references: [id])
}

model StrategicGoal {
  id           String   @id @default(uuid())
  statement    String
  targetValue  Float
  currentValue Float    @default(0)
  tenantId     String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  tenant       Tenant   @relation(fields: [tenantId], references: [id])
}

model StrategicAccess {
  id           String      @id @default(uuid())
  userId       String
  purposeId    String?
  objectiveId  String?
  initiativeId String?
  tenantId     String
  createdAt    DateTime    @default(now())
  initiative   Initiative? @relation(fields: [initiativeId], references: [id])
  objective    Objective?  @relation(fields: [objectiveId], references: [id])
  purpose      Purpose?    @relation(fields: [purposeId], references: [id])
  tenant       Tenant      @relation(fields: [tenantId], references: [id])
  user         User        @relation(fields: [userId], references: [id])

  @@unique([userId, purposeId])
  @@unique([userId, objectiveId])
  @@unique([userId, initiativeId])
}

model AnalyticsSnapshot {
  id        String   @id @default(uuid())
  type      String
  data      String
  tenantId  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  tenant    Tenant   @relation(fields: [tenantId], references: [id])

  @@unique([tenantId, type])
}

model EmergentInsight {
  id        String   @id
  tenantId  String
  tabId     String
  insight   String
  createdAt DateTime @default(now())
  updatedAt DateTime
  Tenant    Tenant   @relation(fields: [tenantId], references: [id])

  @@unique([tenantId, tabId])
}

enum UserRole {
  SUPERADMIN
  ADMIN
  DIRECTOR
  COLLABORATOR
}

enum JobRole {
  TEAM_LEAD
  MEMBER
  SUPERVISOR
}

enum DiscColor {
  RED
  YELLOW
  GREEN
  BLUE
}

enum PurposeType {
  COMPANY
  AREA
  TEAM
}

enum UpdatePeriodicity {
  WEEKLY
  BIWEEKLY
  MONTHLY
  QUARTERLY
  YEARLY
  DAILY
}

enum Horizon {
  H1
  H2
  H3
}

enum KanbanStatus {
  TODO
  IN_PROGRESS
  DONE
}

enum RitualStatus {
  SCHEDULED
  IN_PROGRESS
  COMPLETED
}

enum CommitmentStatus {
  PENDING
  COMPLETED
}

enum TrackingType {
  PERCENTAGE
  UNITS
}

enum MeasurementDirection {
  MAXIMIZE
  MINIMIZE
  TARGET
  COMPLETE
}
